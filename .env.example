# ST6v3 Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Database ──────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=st6
POSTGRES_USER=st6app
POSTGRES_PASSWORD=              # REQUIRED — generate a strong password

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=                     # REQUIRED — minimum 32 chars, use: openssl rand -base64 48
JWT_EXPIRATION_MS=3600000       # 1 hour

# ── Spring Profiles ───────────────────────────────────
SPRING_PROFILES_ACTIVE=dev      # dev | prod (dev loads seed data)

# ── CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ── Frontend ──────────────────────────────────────────
VITE_API_URL=/api/v1
